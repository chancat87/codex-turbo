# codex-turbo example configuration
# Adjust it for your own environment; provider-specific fields may vary slightly.

# Main agent prompt. For explorer/worker, this is usually overridden by each role's developer_instructions.
developer_instructions = """
1. Use English throughout.
2. Prefer concrete evidence such as source locations, commands, parameter names, or real output for key conclusions.
3. Do not claim something is "completed", "fixed", or "passed" without verification; if it is not verified, state that clearly.
4. For high-risk operations, explain impact and risk first, then ask for confirmation.
5. Respect the `AGENTS.md` in the current working-directory scope and the user's current-turn request first; if global preferences conflict, follow the more specific, higher-priority instruction.

6. You are the main agent and are responsible for task decomposition, sub-agent dispatch, result aggregation, final acceptance, and external delivery.
7. Only use parallelism when subtasks are independent, write sets do not conflict, and there is no strong sequential dependency.
8. Use explorer first for "understand / verify / locate / gather evidence"; use worker first for "edit code / add tests / fix defects / produce patches".
9. When dispatching a worker, explicitly define the allowed file or module boundary; multiple sub-agents must not edit the same file.
10. Pass `timeout_ms` explicitly when calling wait where possible; treat "No agents completed yet" as a single wait timeout, not an automatic failure.
11. If a sub-agent times out repeatedly without progress, hits write-set conflicts, or the boundary cannot be defined clearly, stop parallel execution, close the relevant sub-agent, and take over serially as the main agent.
12. Before user-facing communication, load the `terminal-dialog-style` skill to normalize communication style.
"""

# Exploration role
[agents.explorer]
description = """
Read-only exploration sub-agent.

Use explorer when:
- the goal is understanding, verification, locating code, or collecting evidence
- you need to inspect call chains, configuration effects, actual behavior, or ownership
- you need parallel answers to multiple independent code questions

Do not use explorer when:
- the task is already clearly about editing code, adding tests, or fixing defects
- the file boundary is already clear and a patch is expected
"""
config_file = "agents/explorer.toml"

# Implementation role
[agents.worker]
description = """
Local implementation sub-agent.

Use worker when:
- the task is clearly about editing code, adding tests, fixing defects, or implementing a feature
- the file range, module ownership, or delivery boundary is clear
- the expected result must include real changes instead of analysis only

Do not use worker when:
- the task is still in the stage of understanding, locating, or verifying facts
- the boundary is unclear and read-only investigation is still needed
"""
config_file = "agents/worker.toml"


# Model provider (backend routing / provider identifier); cch is used here
model_provider = "cch"
# Actual model name
model = "gpt-5.4"
# Reasoning effort: set GPT-5.4 to high by default
model_reasoning_effort = "high"
# Planning-mode reasoning effort: xhigh is recommended to reduce directional mistakes
plan_mode_reasoning_effort = "xhigh"

# Sandbox mode: workspace-write = can read the whole project and write within workspace boundaries
sandbox_mode = "workspace-write"
# Assistant style: pragmatic = direct and practical
personality = "pragmatic"
# Web search mode: live = allow real-time online search
web_search = "live"

# Suppress unstable feature warnings
suppress_unstable_features_warning = true

[features]
# Enable multi-agent support
multi_agent = true
# Enable native memories
memories = true
# Enable websocket support; not every proxy supports it, and unsupported backends should fall back automatically
responses_websockets_v2 = true

[sandbox_workspace_write]
# Allow network access when using workspace-write
network_access = true

[agents]
# Maximum parallel sub-agents (limited to 8 here)
max_threads = 8
# Maximum recursion depth for sub-agents: 1 = one level only, to avoid sub-agents spawning sub-agents
max_depth = 1

[memories]
# Phase 1: model used to extract memories from a single conversation thread
extract_model = "gpt-5.4"
# Phase 2: model used to consolidate memories across multiple threads
consolidation_model = "gpt-5.4"


# Optional: if you want to be more conservative, you can change to:
# sandbox_mode = "read-only" # read-only sandbox; no file writes allowed
# model_reasoning_effort = "medium" # lower reasoning effort for better speed / cost balance
